<?xml version="1.0" encoding="utf-8"?>
<!--
  Exclui dados sensíveis de auth do backup automático (Android 12+) e das
  transferências D2D. Sem isso, o token do Supabase armazenado via Capacitor
  Preferences (no app_shared_prefs) e o storage do WebView poderiam vazar para
  a nuvem/outro dispositivo ao restaurar, mantendo sessão em equipamento
  diferente do dono original.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" path="app_webview/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" path="app_webview/" />
    </device-transfer>
</data-extraction-rules>
